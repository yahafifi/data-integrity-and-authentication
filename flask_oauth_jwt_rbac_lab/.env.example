# Flask
FLASK_SECRET_KEY=change-this-flask-secret
JWT_SECRET_KEY=change-this-jwt-secret

# SQL Server connection
# Update SERVER and DATABASE based on your Windows SQL Server setup.
# Option 1: Windows Authentication / Trusted Connection
DATABASE_URL=mssql+pyodbc://@localhost/SecurityLabDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Option 2: SQL Server Authentication
# DATABASE_URL=mssql+pyodbc://sa:YourStrongPassword@localhost/SecurityLabDB?driver=ODBC+Driver+17+for+SQL+Server

# Google OAuth Client
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# For local development only. Do not use this in production.
OAUTHLIB_INSECURE_TRANSPORT=1
